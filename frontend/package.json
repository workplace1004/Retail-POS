{
  "name": "pos-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:electron": "vite build --mode electron",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "electron:start-dist": "cross-env ELECTRON_LOAD_DIST=1 electron .",
    "electron:build": "node scripts/clean-electron-release.cjs && vite build --mode electron && node scripts/gen-installer-ico.mjs && electron-builder",
    "build:retail-exe": "pkg scripts/respos-launcher.cjs --targets node18-win-x64 --output release/RETAIL.exe"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "socket.io-client": "^4.7.5",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "pkg": "^5.8.1",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.4.47",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.14",
    "vite": "^5.4.10",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.resrestaurant.pos",
    "productName": "Retail",
    "icon": "public/icon.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "icon": "public/icon.png",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "uninstallDisplayName": "Retail",
      "installerIcon": "build/installer.ico",
      "uninstallerIcon": "build/installer.ico"
    }
  }
}
